  "universal_guidelines": {
    "general": [
      "No gradients for text. Keep text sharp white or light grey.",
      "Avoid 'system' fonts. Use the specified Google Fonts.",
      "Do not use generic 'card' layouts. Use 'Bento' grid arrangements.",
      "Input fields should be 'h-12' or 'h-14' for better touch targets and professional feel.",
      "All interactive elements must have 'transition-all duration-300'."
    ],
    "accessibility": {
      "contrast": "Ensure text is APCA compliant (min Lc 60).",
      "focus": "Visible Neon Lime ring offset on focus."
    },
    "testing": {
      "attribute": "data-testid",
      "format": "kebab-case-descriptive"
    }
  },
  "instructions_to_main_agent": [
    "1. Install 'recharts' for the ML Insights panel.",
    "2. Use 'framer-motion' for page transitions (Landing -> Dashboard).",
    "3. Create the 'Layout' component first to handle the background and font imports.",
    "4. Prioritize the 'Input Form' flow - it is the core interaction.",
    "5. Ensure the 'Mode Badge' logic (Performance/Balanced/Recovery) drives the UI color hints subtly."
  ]
}